{
  "title": "Awaaz — Fleet",
  "uid": "awaaz-fleet",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Conversations / 5m",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(awaaz_conversations_total[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Confirmation rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(awaaz_conversation_outcomes_total{outcome=\"confirmed\"}[5m])) / sum(rate(awaaz_conversation_outcomes_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "End-to-end latency P50/P95/P99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(awaaz_response_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(awaaz_response_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(awaaz_response_latency_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    }
  ]
}
