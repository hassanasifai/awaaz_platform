# =============================================================================
# Awaaz Platform — environment variables
# Copy to `.env` and fill in.  Never commit `.env`.
# =============================================================================

# ============== APP ==============
NODE_ENV=development
ENVIRONMENT=development                      # development | staging | production
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
WORKER_CONCURRENCY=4
LOG_LEVEL=INFO
LOG_FORMAT=json                              # json | console
TZ=Asia/Karachi

# ============== POSTGRES ==============
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=awaaz
POSTGRES_USER=awaaz
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://awaaz:devpassword@postgres:5432/awaaz
DATABASE_URL_SYNC=postgresql+psycopg://awaaz:devpassword@postgres:5432/awaaz
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============== REDIS ==============
REDIS_URL=redis://redis:6379/0

# ============== S3 / MINIO ==============
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_RECORDINGS=awaaz-recordings
S3_BUCKET_MEDIA=awaaz-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_KMS_KEY_ID=

# ============== AUTH ==============
BETTER_AUTH_SECRET=replace-with-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3000
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# ============== ENCRYPTION ==============
PII_ENCRYPTION_KEY=replace-with-32-byte-random-string
PHONE_HASH_KEY=replace-with-32-byte-random-string
WEBHOOK_HMAC_DEFAULT_KEY=replace-with-32-byte-random-string

# ============== PROVIDER SELECTION ==============
WA_PROVIDER=meta_cloud                       # meta_cloud | dialog360 | twilio_wa
LLM_PROVIDER=anthropic                       # anthropic | openai_compat | ollama | vllm
STT_PROVIDER=deepgram                        # deepgram | faster_whisper | indicconformer
TTS_PROVIDER=upliftai                        # upliftai | indic_parler | piper

# ============== WHATSAPP — META CLOUD API (primary) ==============
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_APP_SECRET=
META_WA_VERIFY_TOKEN=replace-with-random-token
META_WA_API_VERSION=v21.0
META_WA_GRAPH_BASE=https://graph.facebook.com

# ============== WHATSAPP — 360DIALOG (alternative) ==============
DIALOG360_API_KEY=
DIALOG360_BASE_URL=https://waba-v2.360dialog.io

# ============== WHATSAPP — TWILIO WA (alternative) ==============
TWILIO_WA_ACCOUNT_SID=
TWILIO_WA_AUTH_TOKEN=
TWILIO_WA_FROM=whatsapp:+14155238886

# ============== ANTHROPIC ==============
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_DEEP=claude-sonnet-4-6
ANTHROPIC_PROMPT_CACHE_TTL=1h

# ============== DEEPGRAM (STT for voice notes / voice channel) ==============
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=ur
DEEPGRAM_KEYTERMS=کراچی,لاہور,اسلام آباد,فیصل آباد,JazzCash,EasyPaisa,RAAST,Daraz

# ============== UPLIFT AI (TTS) ==============
UPLIFTAI_API_KEY=
UPLIFTAI_VOICE_ID=v_meklc281
UPLIFTAI_OUTPUT_FORMAT_VOICE_NOTE=MP3_22050_32
UPLIFTAI_OUTPUT_FORMAT_TELEPHONY=MULAW_8000
UPLIFTAI_BASE_URL=https://api.upliftai.org

# ============== LOCAL STACK (GPU) ==============
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL=Qwen/Qwen3-8B-Instruct-AWQ
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen3:8b-instruct-q4_K_M
FASTER_WHISPER_MODEL=kingabzpro/whisper-large-v3-turbo-urdu
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=int8_float16
INDIC_PARLER_MODEL=ai4bharat/indic-parler-tts
PIPER_VOICE_PATH=/models/piper/ur_PK-fasih-medium.onnx

# ============== LIVEKIT (voice secondary channel) ==============
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-replace-with-random-32-bytes
LIVEKIT_SIP_INBOUND_TRUNK_ID=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# ============== TWILIO PROGRAMMABLE VOICE (voice MVP) ==============
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_AMD_ASYNC=true
TWILIO_AMD_MODE=DetectMessageEnd
TWILIO_AMD_SPEECH_END_THRESHOLD=2500
TWILIO_AMD_TIMEOUT=45

# ============== PTCL/NAYATEL SIP (voice production) ==============
SIP_PROVIDER=ptcl                            # ptcl | nayatel | twilio
SIP_HOST=
SIP_USERNAME=
SIP_PASSWORD=
SIP_FROM_NUMBERS=

# ============== SHOPIFY ==============
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,read_products
SHOPIFY_APP_URL=https://app.awaaz.pk
SHOPIFY_WEBHOOK_VERSION=2026-01

# ============== SMS FALLBACK ==============
SMS_PROVIDER=sendpk                          # sendpk | twilio | jazz_a2p
SMS_API_KEY=
SMS_SENDER_ID=AWAAZ

# ============== STRIPE BILLING ==============
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PER_CONVERSATION_USD=0.05
STRIPE_PRICE_PER_VOICE_MIN_USD=0.07

# ============== OBSERVABILITY ==============
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=awaaz-api
OTEL_RESOURCE_ATTRIBUTES=service.namespace=awaaz,deployment.environment=development
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============== COMPLIANCE ==============
PTA_DNCR_LIST_PATH=/var/awaaz/dncr.txt
CALL_WINDOW_START_PKT=10:00
CALL_WINDOW_END_PKT=20:00
WA_SERVICE_WINDOW_HOURS=24
MAX_RETRY_ATTEMPTS=3
RECORDING_RETENTION_DAYS=30
TRANSCRIPT_RETENTION_DAYS=90
PER_CONVERSATION_COST_CAP_USD=0.50
PER_CALL_COST_CAP_USD=0.50

# ============== RATE LIMITS (per-tenant) ==============
RATE_LIMIT_WEBHOOK_PER_MINUTE=600
RATE_LIMIT_API_PER_MINUTE=300
RATE_LIMIT_DISPATCH_PER_MINUTE=60

# ============== FEATURE FLAGS ==============
FEATURE_VOICE_CHANNEL=false                  # gate the voice path globally
FEATURE_LOCAL_STACK=false                    # enable local LLM/STT/TTS
FEATURE_SHOPIFY_INTEGRATION=true
FEATURE_WOOCOMMERCE_INTEGRATION=true
